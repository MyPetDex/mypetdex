{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://mypetdex-c4315.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://mypetdex-c4315.firebaseapp.com/__/firebase/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
