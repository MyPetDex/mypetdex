{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/pet/:id", "destination": "/pet.html" },
    { "source": "/services", "destination": "/services-section.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
