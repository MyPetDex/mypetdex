{
  "buildCommand": "npm install && npx expo export -p web --clear",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/_expo/static/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://mypetdex-c4315.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://mypetdex-c4315.firebaseapp.com/__/firebase/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
