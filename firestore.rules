rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    // Helper: email on the auth token is verified OR signed in with Google/Apple
    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider == "google.com" ||
        request.auth.token.firebase.sign_in_provider == "apple.com"
      );
    }
    // Helper: user is the demo account (bypasses verification)
    function isDemoAccount() {
      return isSignedIn() && request.auth.token.email == 'demo@mypetdex.app';
    }
    // Helper: user is the admin
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mypetdexapp@gmail.com';
    }

    // Users documents: only the user may read/write their own profile, admin can read/write all
    // Approved shelters and providers can be read by any verified user (for adoption/services browsing)
    match /users/{userId} {
      // Allow creating profile immediately on registration (before email verification)
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Read own profile allowed without email verification — needed for onAuthStateChanged/profile
      // listeners that run immediately after signup, before the user has verified their email.
      // Reading OTHER users' shelter/provider profiles (public browsing) still requires verification.
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId)
        || ((isEmailVerified() || isDemoAccount()) && (
             (resource.data.role == 'shelter' && resource.data.status == 'approved') ||
             (resource.data.role == 'provider')
           ));
      // Update own profile allowed without email verification (needed for onboarding step 2 before verify)
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Delete requires verification
      allow delete: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && request.auth.uid == userId);
      match /{subPath=**} {
        // Read own subcollection docs (e.g. pets) allowed without email verification, same reasoning as above
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow delete: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && request.auth.uid == userId);
      }
    }

    // Shelter pets are public adoption listings — any verified user can read them
    // Collection name is shelter_pets (underscore) to match app code
    match /shelter_pets/{docId} {
      allow read: if isEmailVerified() || isDemoAccount() || isAdmin();
      allow create: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && request.resource.data.shelterId == request.auth.uid);
      allow update, delete: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && resource.data.shelterId == request.auth.uid);
    }

    // Generic rule for top-level collections that store an owning `uid` field
    // Allow create for any signed-in user (covers initial pet save before email verification)
    match /{collection}/{docId} {
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.uid == request.auth.uid);
      allow read, update, delete: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && resource.data.uid == request.auth.uid);
    }

    // Bookings: created by pet owner (uid), readable/updatable by both owner and provider
    match /bookings/{docId} {
      allow create: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && request.resource.data.uid == request.auth.uid);
      allow read, update: if isAdmin()
        || ((isEmailVerified() || isDemoAccount()) && resource.data.uid == request.auth.uid)
        || ((isEmailVerified() || isDemoAccount()) && resource.data.providerId == request.auth.uid);
      allow delete: if isAdmin() || ((isEmailVerified() || isDemoAccount()) && resource.data.uid == request.auth.uid);
    }

    // Reviews: any verified user can create, provider can read their own, admin manages all
    match /reviews/{docId} {
      allow create: if isAdmin() || (isEmailVerified() || isDemoAccount());
      allow read: if isAdmin()
        || ((isEmailVerified() || isDemoAccount()) && resource.data.uid == request.auth.uid)
        || ((isEmailVerified() || isDemoAccount()) && resource.data.providerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Seeded providers from Google Places — any signed-in user can read
    match /seedProviders/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Shop products — readable by all verified users, writable by admin only
    match /shopProducts/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Featured products (Amazon/Chewy) — readable by any signed-in user
    match /featured_products/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Deny everything else by default (covers any other paths)
    // Public stats (user count for website)
    match /stats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
