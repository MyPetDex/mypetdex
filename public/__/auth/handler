<!DOCTYPE html>
<html lang="en">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<meta name="theme-color" content="#4486F4">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap" rel="stylesheet">
<style>
  html, body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(165deg, #4486F4 0%, #5B9CF8 38%, #F0F5FF 72%, #F0F5FF 100%);
    font-family: 'Nunito', -apple-system, BlinkMacSystemFont, sans-serif;
    overflow-x: hidden;
  }
  #mpd-auth-brand {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 0;
    pointer-events: none;
    padding: 24px;
    box-sizing: border-box;
  }
  #mpd-auth-brand .logo {
    width: 88px;
    height: 88px;
    border-radius: 22px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 16px 48px rgba(47, 106, 216, 0.35);
    margin-bottom: 18px;
  }
  #mpd-auth-brand .logo img {
    width: 62px;
    height: 62px;
    border-radius: 14px;
    object-fit: contain;
  }
  #mpd-auth-brand h1 {
    margin: 0 0 6px;
    color: #fff;
    font-weight: 900;
    font-size: 28px;
    letter-spacing: -0.5px;
    text-shadow: 0 2px 16px rgba(47, 106, 216, 0.35);
  }
  #mpd-auth-brand p {
    margin: 0;
    color: rgba(255, 255, 255, 0.92);
    font-size: 14px;
    font-weight: 700;
  }
  .firebase-container,
  .mdl-card {
    position: relative !important;
    z-index: 2 !important;
    background: #fff !important;
    border-radius: 20px !important;
    box-shadow: 0 20px 50px rgba(68, 134, 244, 0.18) !important;
    border: 1px solid rgba(255, 255, 255, 0.9) !important;
    max-width: 92vw !important;
  }
  #continue,
  .mdl-button--colored {
    background: #4486F4 !important;
    color: #fff !important;
    font-family: 'Nunito', sans-serif !important;
    font-weight: 800 !important;
    border-radius: 12px !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    box-shadow: 0 8px 24px rgba(68, 134, 244, 0.35) !important;
  }
</style>
<script type="text/javascript" src="experiments.js"></script>
<script type="text/javascript" src="handler.js"></script>
<script type="text/javascript" nonce="firebase-auth-helper">
var POST_BODY = '{{POST_BODY}}';
fireauth.oauthhelper.widget.initialize();
</script>
</head>
<body>
<div id="mpd-auth-brand" aria-hidden="true">
  <div class="logo"><img src="https://app.mypetdex.app/logo.png" alt="" width="62" height="62"></div>
  <h1>MyPetDex</h1>
  <p>Secure sign-in…</p>
</div>
</body>
</html>
